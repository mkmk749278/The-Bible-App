    <!-- 3AM / Crisis Mode -->
    <string name="crisis_title">You are not alone</string>
    <string name="crisis_back">Back</string>
    <string name="crisis_tool_entry">I\'m not okay right now</string>
    <string name="crisis_menu_entry">I\'m not okay</string>
    <string name="crisis_heading">God sees you right now.</string>
    <string name="crisis_reassurance">Whatever you are carrying tonight, you don\'t have to carry it alone. Breathe. Rest here for a moment.</string>
    <string name="crisis_listen">Just listen</string>
